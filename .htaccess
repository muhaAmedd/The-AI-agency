# 1) Disable folder browsing
Options -Indexes

# 2) Force HTTPS (Redirect all HTTP traffic to HTTPS)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3) Protect sensitive files (.htaccess, .htpasswd, error logs, etc.)
<FilesMatch "^\.ht|error_log|error\.log|debug\.log">
    Require all denied
</FilesMatch>

# Prevent access to the assets folder directories directly (though -Indexes covers browsing, we can restrict specific file types if needed, but usually -Indexes is enough)

# 4) Custom 404 page routing
ErrorDocument 404 /404.html

# 5) Block Hotlinking (Prevent other sites from stealing bandwidth by directly linking your images/videos)
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https?://(www\.)?theaiagency\.com [NC]
# Note: Update 'theaiagency.com' above to your actual domain name once deployed!
RewriteRule \.(jpg|jpeg|png|gif|webp|mp4|webm)$ - [F,NC]
